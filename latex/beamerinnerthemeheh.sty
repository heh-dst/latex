\mode<presentation>

\RequirePackage{tikz}
\RequirePackage{heh-common}

\newsavebox{\heh@logo}
\newlength{\wdoflogo}
\sbox{\heh@logo}{\scalebox{0.9}{\HEHLogo}}
\settowidth{\wdoflogo}{\usebox{\heh@logo}}

\setbeamertemplate{items}[circle]
\setbeamertemplate{sections/subsections in toc}[circle]

\defbeamertemplate*{title page}{heh}[1][]
{
  \thispagestyle{empty}%
  \begin{tikzpicture}[remember picture, overlay]%
    \node[anchor=north west,xshift=4pt,yshift=-4pt] at (current page.north west) {\usebox{\heh@logo}};%
    \node[opacity=.3,anchor=south west] at (current page.south west) {\pgfuseimage{logo-wbe}\hspace{1em}\pgfuseimage{logo-pole}};%
    \pic[anchor=south east,scale=.6,xshift=-2em,yshift=2em] at (current page.south east) {hehballs};%
  \end{tikzpicture}%
  \vfill
  \begingroup
  \usebeamertemplate{title}
  \usebeamertemplate{author}
  \endgroup
  \vfill
}[action]{
  \setbeamertemplate{title}[default][#1]
  \setbeamertemplate{author}[default][#1]
}



\mode
<all>
